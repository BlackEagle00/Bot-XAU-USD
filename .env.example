# Plantilla de variables de entorno — copia este archivo a ".env" y rellena tus valores.
#   cp .env.example .env
# El archivo .env real está en .gitignore (NUNCA se sube al repositorio).

# ── Credenciales MetaTrader 5 ─────────────────────────────────────────────────
# Deja MT5_LOGIN=0 para usar la cuenta que ya tengas abierta en el terminal MT5.
MT5_LOGIN=0
MT5_PASSWORD=
MT5_SERVER=

# ── Notificaciones Telegram (opcional) ────────────────────────────────────────
# Mismo bot/chat para los 4 bots. Si los dejas vacíos, las notificaciones
# se desactivan solas (sin error).
#   TELEGRAM_BOT_TOKEN → te lo da @BotFather al crear el bot
#   TELEGRAM_CHAT_ID   → tu id numérico (háblale a @userinfobot)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
